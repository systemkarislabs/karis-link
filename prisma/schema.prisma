generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  active      Boolean  @default(true)
  adminUser   String
  adminPass   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sellers    Seller[]
  qrCodes    QrCode[]
  pageClicks PageClickEvent[]
}

model Seller {
  id        String   @id @default(cuid())
  name      String
  whatsapp  String
  role      String?
  active    Boolean  @default(true)
  featured  Boolean  @default(false)
  clicks    Int      @default(0)
  photo     String?
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events    SellerClickEvent[]
}

model QrCode {
  id        String   @id @default(cuid())
  name      String
  slug      String
  url       String
  active    Boolean  @default(true)
  visits    Int      @default(0)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PageClickEvent {
  id        String   @id @default(cuid())
  source    String   @default("direct")
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SellerClickEvent {
  id        String   @id @default(cuid())
  sellerId  String
  source    String   @default("direct")
  createdAt DateTime @default(now())
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  adminUser           String
  adminPass           String
  adminEmail          String?
  logo                String?
  active              Boolean      @default(true)
  cityGroupingEnabled Boolean      @default(false)
  createdAt           DateTime     @default(now())
  sellers             Seller[]
  qrcodes             QrCode[]
  cities              TenantCity[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, expiresAt])
}

model TenantCity {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sellers   Seller[]
  createdAt DateTime @default(now())

  @@index([tenantId, active])
  @@unique([tenantId, name])
}

model SuperAdminAccount {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Seller {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  image     String?
  clicks    Int      @default(0)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  cityId    String?
  city      TenantCity? @relation(fields: [cityId], references: [id])
  sortOrder Int         @default(0)
  events    SellerClickEvent[]

  @@index([tenantId])
  @@index([cityId])
  @@index([tenantId, sortOrder])
}

model QrCode {
  id        String   @id @default(cuid())
  name      String
  slug      String
  url       String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@unique([tenantId, slug])
}

model PageClickEvent {
  id        String   @id @default(cuid())
  tenantId  String
  source    String?
  campaign  String?
  createdAt DateTime @default(now())

  @@index([tenantId, source, campaign, createdAt])
}

model SellerClickEvent {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id])
  source    String?  // Adicionado para rastrear a origem (ex: qr, bio, etc)
  campaign  String?
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([source, campaign, createdAt])
}

// Rate-limiting compartilhado entre instâncias.
// Substitui o bucket em-memória que não funciona em serverless multi-instância.
model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

// Trilha de auditoria para eventos sensíveis (logins, exclusões, troca de credenciais).
model AuditLog {
  id        String   @id @default(cuid())
  event     String   // ex: 'super_login_success', 'tenant_delete', 'super_credentials_update'
  actor     String?  // username/identificador de quem executou
  ip        String?
  tenantId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([tenantId])
  @@index([createdAt])
}

# Variáveis de ambiente necessárias para produção

# URL de conexão com PostgreSQL (via connection pooler do Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL direta (sem pooler) para as migrations do Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL base do site publicado (usado nos QR Codes)
NEXT_PUBLIC_BASE_URL="https://seu-site.vercel.app"

# Credenciais do admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin"

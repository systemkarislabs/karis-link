# Variaveis de ambiente necessarias para producao

# URL de conexao com PostgreSQL (via connection pooler do Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL direta (sem pooler) para as migrations do Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL base do site publicado (usado nos QR Codes e links de bio)
NEXT_PUBLIC_BASE_URL="https://link.karisnegocios.com.br"

# Segredo usado para assinar os cookies de sessao
AUTH_SECRET="troque-este-valor-por-um-segredo-longo"

# Credenciais do super-admin
SUPER_ADMIN_USER="superadmin"

# Escolha uma das opcoes abaixo:
# 1. texto puro (somente para desenvolvimento local)
SUPER_ADMIN_PASS="troque-esta-senha"
# 2. hash bcrypt (recomendado para producao)
# SUPER_ADMIN_PASS_HASH="$2b$12$..."

# Recuperacao de senha por e-mail
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Karis Negocios <contatos@karisnegocios.com.br>"

# Supabase Storage para logos/fotos novas
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="karis-link-assets"
